# Shared Shadou stack paths — copy to ~/.config/shadou/shadou-stack.env
# Used by: shadou-engine, shadou-studio-api, shadou-studio-ui (and install.sh)

SHADOU_REPO=%h/workspace/shadou
SHADOU_TENANTS_ROOT=%h/workspace
SHADOU_PYTHON=%h/miniconda3/bin/python3
NODE_BIN=%h/.nvm/versions/node/v22.11.0/bin/node

# Optional: default engine workspace (per-request SHADOU_HOME still set by Studio/bridge)
# SHADOU_HOME=%h/workspace/shadou-tenant-kommu

# LLM keys: set in tenant workspace .env or here for all services
# DEEPSEEK_API_KEY=
