[Unit]
Description=Shadou.io nginx edge (Docker :8780)
After=docker.service network-online.target shadou-studio-api.service
Wants=network-online.target
PartOf=shadou.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=%h/workspace/shadou/studio/deploy/shadou
ExecStart=/usr/bin/docker compose up -d --remove-orphans
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120

[Install]
WantedBy=shadou.target
