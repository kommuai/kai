# Copy to ~/.config/kai/whatsapp-bridge.env and adjust paths.
# Used by: systemctl --user start kai-whatsapp-bridge.service

# Baileys requires Node 20+ (import attributes). install.sh auto-detects; override if needed.
NODE_BIN=%h/.nvm/versions/node/v22.22.2/bin/node
KAI_PYTHON=%h/miniconda3/bin/python3

KAI_TENANTS_ROOT=%h/workspace
KAI_REPO=%h/workspace/kai
WHATSAPP_BRIDGE_PORT=18791
WHATSAPP_BRIDGE_HOST=127.0.0.1
WHATSAPP_WORKER_SCAN_MS=15000
WHATSAPP_WORKER_ENABLED=1
LOG_LEVEL=info

# Tenant agent replies (kai_inbound.py) need your LLM key in each tenant workspace or global env:
# DEEPSEEK_API_KEY=...
