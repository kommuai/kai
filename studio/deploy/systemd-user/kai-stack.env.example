# Shared Kai stack paths — copy to ~/.config/kai/kai-stack.env
# Used by: kai-engine, kai-studio-api, kai-studio-ui (and install.sh)

KAI_REPO=%h/workspace/kai
KAI_TENANTS_ROOT=%h/workspace
KAI_PYTHON=%h/miniconda3/bin/python3
NODE_BIN=%h/.nvm/versions/node/v22.11.0/bin/node

# Optional: default engine workspace (per-request KAI_HOME still set by Studio/bridge)
# KAI_HOME=%h/workspace/kai-tenant-kommu

# LLM keys: set in tenant workspace .env or here for all services
# DEEPSEEK_API_KEY=
